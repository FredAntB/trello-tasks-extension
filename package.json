{
  "publisher": "FredAntB",
  "name": "tar-trello",
  "displayName": "Task at Reach - Trello",
  "description": "A way for you to see your current tasks from a trello board, move them to another column, add comments if required, and create a git branch for each task using a given code for their name.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.108.2"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onUri"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Settings Task At Reach - Trello",
      "type": "object",
      "properties": {
        "tar-trello.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether TAR - Trello is enabled."
        }
      }
    },
    "commands": [
      {
        "command": "tar-trello.login",
        "title": "Login to Trello",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "tar-trello.logout",
        "title": "Logout of Trello",
        "icon": "$(debug-connected)"
      },
      {
        "command": "tar-trello.load-boards",
        "title": "Load Boards"
      },
      {
        "command": "tar-trello.reload-boards",
        "title": "Refresh Boards",
        "icon": "$(refresh)"
      },
      {
        "command": "tar-trello.reload-tasks",
        "title": "Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "tar-trello.select-board",
        "title": "Select Board"
      },
      {
        "command": "tar-trello.view-tasks",
        "title": "View Tasks"
      },
      {
        "command": "tar-trello.reset-data",
        "title": "Reset Trello Data",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tar-trello.logout",
          "when": "view == tar-trello-boards-view && tar-trello.authenticated",
          "group": "navigation"
        },
        {
          "command": "tar-trello.login",
          "when": "view == tar-trello-boards-view && !tar-trello.authenticated",
          "group": "navigation"
        },
        {
          "command": "tar-trello.reload-boards",
          "when": "view == tar-trello-boards-view && tar-trello.authenticated",
          "group": "navigation"
        },
        {
          "command": "tar-trello.reset-data",
          "when": "view == tar-trello-boards-view && tar-trello.authenticated",
          "group": "navigation@99"
        },
        {
          "command": "tar-trello.reload-tasks",
          "when": "view == tar-trello-tasks-view && tar-trello.authenticated",
          "group": "navigation"
        }
      ]
    },
    "walkthroughs": [
      {
        "icon": "resources/icon-white.png",
        "id": "tutorial",
        "title": "Get started with TarTrello",
        "description": "Let's setup your Trello integration",
        "steps": [
          {
            "id": "login",
            "title": "Login",
            "description": "To begin, you'll need to log in to your Trello account. Click the button below to authenticate and connect your Trello boards with TarTrello.\n[Login](command:tar-trello.login)",
            "media": {
              "image": "images/trello-login.png",
              "altText": "Login example image"
            }
          },
          {
            "id": "select-board",
            "title": "Select Board",
            "description": "Now that you're logged in, it's time to select the Trello board you want to work with. Choose the board that contains your tasks to get started.\n[Select Board](command:tar-trello.select-board)",
            "media": {
              "image": "images/trello-select-board.png",
              "altText": "Select Board example image"
            }
          },
          {
            "id": "view-tasks",
            "title": "View Tasks",
            "description": "With your board selected, you can now view your current tasks directly within VS Code. This allows you to manage your tasks without switching contexts.\n[View Tasks](command:tar-trello.view-tasks)",
            "media": {
              "image": "images/trello-view-tasks.png",
              "altText": "View Tasks example image"
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tar-trello",
          "title": "Task At Reach",
          "icon": "resources/icon-white.png",
          "iconDark": "resources/icon-black.png"
        }
      ]
    },
    "views": {
      "tar-trello": [
        {
          "type": "webview",
          "id": "tar-trello-boards-view",
          "name": "Trello Boards"
        },
        {
          "type": "webview",
          "id": "tar-trello-tasks-view",
          "name": "Trello Tasks"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "tar-trello-boards-view",
        "contents": "In order to use tar capabilities, please login first.\n[Login](command:tar-trello.login)",
        "when": "config.tar-trello.enabled && tar-trello.fresh",
        "priority": 1,
        "icon": {
          "light": "resources/welcome-light.png",
          "dark": "resources/welcome-dark.png"
        }

      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/oauth": "^0.9.6",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "oauth": "^0.10.2"
  }
}
