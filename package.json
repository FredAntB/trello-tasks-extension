{
  "publisher": "fuoco",
  "name": "tar-trello",
  "displayName": "Task at Reach - Trello",
  "description": "A way for you to see your current tasks from a trello board.",
  "version": "0.1.2",
  "license": "GPL-3.0-only",
  "engines": {
    "vscode": "^1.108.2"
  },
  "icon": "resources/icon-white.png",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "github:FredAntB/trello-tasks-extension.git"
  },
  "activationEvents": ["onUri"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Settings Task At Reach - Trello",
      "type": "object",
      "properties": {
        "tar-trello.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether TAR - Trello is enabled."
        }
      }
    },
    "commands": [
      {
        "command": "tar-trello.login",
        "title": "Login to Trello",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "tar-trello.logout",
        "title": "Logout of Trello",
        "icon": "$(debug-connected)"
      },
      {
        "command": "tar-trello.reload-boards",
        "title": "Refresh Boards",
        "icon": "$(refresh)"
      },
      {
        "command": "tar-trello.reload-tasks",
        "title": "Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "tar-trello.select-board",
        "title": "Select Board"
      },
      {
        "command": "tar-trello.view-tasks",
        "title": "View Tasks"
      },
      {
        "command": "tar-trello.reset-data",
        "title": "Reset Trello Data",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tar-trello.logout",
          "when": "view == tar-trello-boards-view && tar-trello.authenticated",
          "group": "navigation"
        },
        {
          "command": "tar-trello.login",
          "when": "view == tar-trello-boards-view && !tar-trello.authenticated",
          "group": "navigation"
        },
        {
          "command": "tar-trello.reload-boards",
          "when": "view == tar-trello-boards-view && tar-trello.authenticated",
          "group": "navigation"
        },
        {
          "command": "tar-trello.reset-data",
          "when": "view == tar-trello-boards-view && tar-trello.authenticated",
          "group": "navigation@99"
        },
        {
          "command": "tar-trello.reload-tasks",
          "when": "view == tar-trello-tasks-view && tar-trello.authenticated",
          "group": "navigation"
        }
      ]
    },
    "walkthroughs": [
      {
        "icon": "resources/icon-white.png",
        "id": "tutorial",
        "title": "Get started with TarTrello",
        "description": "Let's setup your Trello integration",
        "steps": [
          {
            "id": "login",
            "title": "Login",
            "description": "To begin, you'll need to log in to your Trello account by following the gif or clicking the button below.\n[Login](command:tar-trello.login)",
            "media": {
              "altText": "Login to trello",
              "image": "resources/login.gif"
            }
          },
          {
            "id": "select-board",
            "title": "Select Board",
            "description": "Now that you're logged in the boards will be displayed automatically. Choose one board from the list to proceed.",
            "media": {
              "altText": "Select a board",
              "image": "resources/select-board.gif"
            }
          },
          {
            "id": "refresh-boards",
            "title": "Refresh Boards",
            "description": "If you don't see your board, or if you've made changes to your boards on Trello, you can refresh the list of boards by clicking the refresh button in the top right corner of the boards view.",
            "media": {
              "altText": "Refresh boards",
              "image": "resources/refresh-boards.gif"
            }
          },
          {
            "id": "select-list",
            "title": "Select List",
            "description": "After selecting a board, you can choose a list within that board to focus on. This will allow you to visualize tasks within that specific list.",
            "media": {
              "altText": "Select a list",
              "image": "resources/select-list.gif"
            }
          },
          {
            "id": "view-tasks",
            "title": "View Tasks",
            "description": "With your board selected, you can now view your current tasks directly within VS Code. This allows you to manage your tasks without switching contexts.",
            "media": {
              "altText": "View tasks",
              "image": "resources/view-tasks.gif"
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tar-trello",
          "title": "Task At Reach",
          "icon": "resources/icon-white.png",
          "iconDark": "resources/icon-black.png"
        }
      ]
    },
    "views": {
      "tar-trello": [
        {
          "type": "webview",
          "id": "tar-trello-boards-view",
          "name": "Trello Boards"
        },
        {
          "type": "webview",
          "id": "tar-trello-tasks-view",
          "name": "Trello Tasks"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "tar-trello-boards-view",
        "contents": "In order to use tar capabilities, please login first.\n[Login](command:tar-trello.login)",
        "when": "config.tar-trello.enabled && tar-trello.fresh",
        "priority": 1,
        "icon": {
          "light": "resources/welcome-light.png",
          "dark": "resources/welcome-dark.png"
        }

      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build:config": "node ./scripts/generate-builtins.mjs",
    "compile": "npm run build:config && tsc -p ./",
    "watch": "npm run build:config && tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsce:package": "vsce package --readmePath README.marketplace.md",
    "vsce:publish": "vsce publish --readmePath README.marketplace.md"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/oauth": "^0.9.6",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "oauth": "^0.10.2"
  }
}
